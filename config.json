{
  "wakeWord": {
    "model": "models/hey_claude.onnx",
    "threshold": 0.3
  },
  "audio": {
    "sampleRate": 16000,
    "silenceThreshold": "1.5%",
    "silenceTimeout": 1.5,
    "maxRecordingSeconds": 15,
    "preRollSeconds": 1.5,
    "vadThreshold": 0.015
  },
  "stt": {
    "provider": "groq",
    "groqModel": "whisper-large-v3-turbo",
    "fallbackProvider": "local",
    "localModel": "small",
    "temperature": 0.0
  },
  "llm": {
    "model": "claude-sonnet-4-6",
    "maxTokens": 300,
    "maxSessionTurns": 25,
    "sessionKeepAliveMinutes": 5
  },
  "tts": {
    "command": "say",
    "voice": "Samantha",
    "rate": 190
  },
  "conversation": {
    "followUpTimeout": 4.5,
    "maxFollowUpTurns": 5
  }
}
